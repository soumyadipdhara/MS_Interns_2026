# DATABASE_URL is intentionally omitted here — the backend defaults to an
# absolute path (backend/worksphere.db) so the database file is always in the
# same place no matter which directory you launch `uvicorn` from. Only set
# this if you want to point at a different database (e.g. PostgreSQL).
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
